# Database
DATABASE_URL=postgresql://aidebug:aidebug_secret@localhost:5435/ai_debug

# Auth
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Encryption - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# LLM Provider: openai | gemini
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4.1
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.0-flash

# App
BACKEND_PORT=4000
BACKEND_URL=http://localhost:4000
API_URL=http://localhost:4000/api
WS_URL=ws://localhost:4000/agent/ws
# Optional: public tunnel URL for remote agent install/WebSocket (OAuth stays on localhost)
# PUBLIC_BACKEND_URL=https://your-tunnel.trycloudflare.com
FRONTEND_URL=http://localhost:3000
REPOS_DATA_DIR=./data/repos

# GitHub OAuth
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_SCOPES=read:user,user:email,repo
# Defaults to http://localhost:BACKEND_PORT/api/oauth/github/callback
# GITHUB_OAUTH_CALLBACK_URL=http://localhost:4000/api/oauth/github/callback
OAUTH_STATE_SECRET=change-me-oauth-state-secret

# Agent
AGENT_JWT_SECRET=change-me-agent-jwt-secret
AGENT_TOKEN_EXPIRY_HOURS=24
AGENT_HEARTBEAT_TIMEOUT_SEC=90
INSTALL_SCRIPT_URL=http://localhost:4000/agent/install.sh

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
